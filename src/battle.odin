WhichAlteration :: enum {
	G_Scavenger = 1,
	G_Survivalist,

	Enfeeble,
	Fatigue,
}

Alteration :: struct {
	which: WhichAlteration,
	degree: int,
	turns_left: int, // -1 = infinite
}

NIL_ROLE :: WhichRole(0)
WhichRole :: enum {
	ACC = 1, // Accumulator - build combo
	OBL = 2, // Obliterator - destroy combo for hi dmg
	ITM = 3, // Itemer - use items
	MED = 4, // Medic - heal
	MAN = 5, // Manipulator - manipulate time (buff)
	ALT = 6, // Hinderer - hinder enemies (debuff)
}
g_which_role_strs := [WhichRole]string{
	.ACC = "ROLE_ABBREV_ACC",
	.OBL = "ROLE_ABBREV_OBL",
	.ITM = "ROLE_ABBREV_ITM",
	.MED = "ROLE_ABBREV_MED",
	.MAN = "ROLE_ABBREV_MAN",
	.ALT = "ROLE_ABBREV_ALT",
}

WhichAbility :: enum int {
	NIL = 0,
	ACC_BEGIN = 1,
		ACC_Strike = ACC_BEGIN, // 0.25x base damage
		ACC_Psych, // magic version of strike
		ACC_Blitzkrieg, // Ultimate, keeps attacking and adding +1 combo until interrupted. Keep goes down -1 each attack.

	ACC_END = ACC_BEGIN + 200,
	OBL_BEGIN = ACC_END,
		OBL_Attack = OBL_BEGIN, // 16x damage of ACC, or 4x base
		OBL_Flare, // magic version of attack
		OBL_Obliteration, // Ultimate, destroys combo back to 0x. Can reduce combo as low as -50x

	OBL_END = ACC_BEGIN + 400,
	MAN_BEGIN = OBL_END,
		MAN_Freeze = MAN_BEGIN, // stops 1 enemy bar for a short time
		MAN_Burnout, // fire-elemental freeze
		MAN_Boost, // boosts an ally's bar speed
		MAN_Again, // repeat last chain of an ally instantly
		MAN_TimeReversal, // Ultimate, enemy bars tick backwards while leeching the same amount of time to allies

	MAN_END = ACC_BEGIN + 600,
	ALT_BEGIN = MAN_END,
		ALT_Defend = ALT_BEGIN,
		ALT_Focus,

	ALT_END = ACC_BEGIN + 800,
	MED_BEGIN = ALT_END,
		MED_Heal = MED_BEGIN,

	MED_END = ACC_BEGIN + 1_000,
	ITM_BEGIN = MED_END, // offsets dynamically generated for ITM role
	ITM_END = ACC_BEGIN + 4_000,
} // ITM_* abilities don't exist (battle opts dynamically generated by inventory) so they are excluded here
AbilityTargetType :: enum { SingleParty, SingleEnemy, AllParty, AllEnemy, All }

MAX_NUM_ALTERATIONS :: 256
MAX_NUM_ABILITIES :: 256
Entity :: struct { // @FullyImmediateData (we need to be able to directly serialize)
	hp, max_hp,
	dext,
	intl: i32,

	alterations: [MAX_NUM_ALTERATIONS]Alteration,
	alterations_head: int,

	temp_alterations: [MAX_NUM_ALTERATIONS]Alteration,
	temp_alterations_head: int,

	abilities: [MAX_NUM_ABILITIES]WhichAbility,
	abilities_head: int,
}

PartyMember :: struct {
	using entity: Entity,
	recruited: b32,
}
TERRY :: 0
VIOLA :: 1
DEX :: 2
NUM_CHARACTERS :: 3

